{
  "name": "bun-react-template",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n TAILWIND,SERVER,CLIENT,TSR -c green,cyan,magenta,yellow \"bun run tailwind:watch\" \"bun run dev:server\" \"bun run dev:client\" \"bun run watch-routes\"",
    "dev:server": "bun --hot src/index.tsx",
    "dev:client": "bun build ./src/index.html --outdir=public --target=browser --watch",
    "start": "bun src/index.tsx",
    "build": "bun run build:client",
    "build:client": "NODE_ENV=production rm -rf public && bun build ./src/index.html --outdir=public --sourcemap --target=browser --minify --define:process.env.NODE_ENV='\\\"production\\\"' --env='BUN_PUBLIC_*'",
    "prebuild": "bun run tailwind && bun run generate-routes && bun run lint && bun run format && bun run test",
    "generate-routes": "tsr generate",
    "watch-routes": "tsr watch",
    "tailwind": "tailwindcss -i ./src/styles/index.css -o ./src/styles/output.css --minify",
    "tailwind:watch": "tailwindcss -i ./src/styles/index.css -o ./src/styles/output.css --watch --minify",
    "lint": "biome check . --write",
    "format": "biome format --write .",
    "test": "bun test"
  },
  "dependencies": {
    "@base-ui-components/react": "^1.0.0-rc.0",
    "@tailwindcss/cli": "^4.1.18",
    "@tanstack/react-form": "^1.27.7",
    "@tanstack/react-query": "^5.90.20",
    "@tanstack/react-query-devtools": "^5.91.2",
    "@tanstack/react-router": "^1.157.5",
    "@trpc/client": "^11.8.1",
    "@trpc/server": "^11.8.1",
    "@trpc/tanstack-react-query": "^11.8.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.563.0",
    "marked": "^17.0.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "sonner": "^2.0.7",
    "superjson": "^2.2.6",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.12",
    "@tanstack/react-router-devtools": "^1.157.5",
    "@tanstack/router-cli": "^1.157.5",
    "@types/bun": "latest",
    "@types/react": "^19.2.9",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.1"
  }
}
